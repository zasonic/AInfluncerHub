{
  "$schema":     "https://schema.tauri.app/config/2",
  "productName": "AinfluencerHub",
  "version":     "1.0.0",
  "identifier":  "com.ainfluencerhub.app",

  "build": {
    "frontendDist":        "../dist",
    "devUrl":              "http://localhost:1420",
    "beforeDevCommand":    "npm run dev",
    "beforeBuildCommand":  "npm run build"
  },

  "app": {
    "windows": [
      {
        "title":      "AinfluencerHub",
        "width":      1280,
        "height":     820,
        "minWidth":   960,
        "minHeight":  640,
        "resizable":  true,
        "fullscreen": false,
        "decorations": true,
        "center":     true
      }
    ],
    "security": {
      "csp": null
    }
  },

  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "python/**": "python/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },

  "plugins": {
    "dialog": {},
    "opener": {},
    "shell": {
      "open": true
    }
  }
}
