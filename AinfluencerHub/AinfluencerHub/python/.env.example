# Copy to .env and fill in.
# The backend also reads the token from the in-app Settings modal, which
# persists it at ~/.ai_influencer_hub/settings.json.

# HuggingFace read token — needed for SDXL, IP-Adapter, and JoyCaption downloads.
# Get one at https://huggingface.co/settings/tokens
HF_TOKEN=

# Accepted alias (either works):
HUGGING_FACE_HUB_TOKEN=
